---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const all = (await getCollection('projects', ({ data }) => !data.draft)).sort(
    (a, b) => a.data.order - b.data.order
  );
  return all.map((project, i) => ({
    params: { slug: project.id },
    props: { project, next: all[(i + 1) % all.length] },
  }));
}

const { project, next } = Astro.props;
const { Content } = await render(project);
const d = project.data;

const meta = [
  ['Category', d.categories.join(' | ')],
  ['Year', d.year],
  ['Role', d.role],
  ['Tools', d.tools.join(', ')],
].filter(([, v]) => v);
---

<Base title={d.title} description={d.description}>
  <article class="pt-28 sm:pt-36">
    <header class="wrap">
      <a href="/#work" class="u-link text-soft hover:text-ink text-sm transition-colors" data-enter>
        ← All work
      </a>

      <h1 class="display mt-6 text-[clamp(2.9rem,9vw,6rem)] leading-[0.98] tracking-[-0.04em]">
        <span class="mask"><span class="mi gate-mi">{d.title}</span></span>
      </h1>

      <div class="mt-8 flex max-w-3xl flex-col gap-8 sm:mt-10">
        <p class="text-ink/80 max-w-xl text-lg leading-relaxed" data-enter>{d.description}</p>
        <dl class="grid grid-cols-2 gap-x-8 gap-y-5 text-sm sm:grid-cols-4" data-enter>
          {
            meta.map(([k, v]) => (
              <div>
                <dt class="text-soft text-xs tracking-[0.06em] uppercase">{k}</dt>
                <dd class="text-ink mt-1.5 font-medium">{v}</dd>
              </div>
            ))
          }
          {
            d.externalUrl && (
              <div>
                <dt class="text-soft text-xs tracking-[0.06em] uppercase">Live</dt>
                <dd class="mt-1.5">
                  <a class="u-link font-medium" href={d.externalUrl} target="_blank" rel="noopener noreferrer">
                    Open link ↗
                  </a>
                </dd>
              </div>
            )
          }
        </dl>
      </div>

      {/* cover */}
      <div class="mt-10 overflow-hidden rounded-[24px] sm:mt-14 sm:rounded-[32px]" data-cover>
        <Image
          src={d.cover}
          alt={d.coverAlt ?? `Cover of ${d.title}`}
          class="block h-auto w-full"
          widths={[760, 1100, 1600]}
          sizes="(min-width: 1152px) 1088px, 92vw"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </header>

    {/* markdown body — images do the talking */}
    <div class="wrap">
      <div class="article mt-14 sm:mt-20">
        <Content />
      </div>
    </div>

    {/* next project */}
    <a
      href={`/work/${next.id}/`}
      class="group border-ink/10 hover:bg-lime mt-24 block border-y transition-colors duration-500 sm:mt-32"
    >
      <div class="wrap flex items-center justify-between gap-6 py-12 sm:py-16">
        <div>
          <p class="text-soft group-hover:text-ink/60 text-sm transition-colors">Next project</p>
          <p class="display mt-2 text-[clamp(1.9rem,5vw,3.8rem)] leading-none tracking-[-0.03em]">
            {next.data.title}
          </p>
        </div>
        <svg
          class="size-10 shrink-0 transition-transform duration-500 group-hover:translate-x-2 sm:size-14"
          viewBox="0 0 24 24"
          fill="none"
          aria-hidden="true"
        >
          <path d="M4 12h16m0 0-6-6m6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </div>
    </a>
  </article>
</Base>
