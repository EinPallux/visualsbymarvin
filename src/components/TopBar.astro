---
import { site } from '../data/site';
---

<header class="topbar absolute inset-x-0 top-0 z-40">
  <div class="wrap flex items-center justify-between gap-3 py-5">
    <a href="/" class="u-link shrink-0 text-sm font-semibold tracking-tight">
      {site.name}
      <span class="text-soft ml-2 hidden font-normal sm:inline">— {site.role}</span>
    </a>

    <div class="flex items-center gap-3 sm:gap-4">
      {/* availability — hidden on phones so the toggle always fits */}
      <div class="text-soft hidden items-center gap-2.5 text-sm sm:flex">
        <span class="relative flex size-2">
          <span class="bg-lime-ink absolute inline-flex h-full w-full animate-ping rounded-full opacity-60"
          ></span>
          <span class="bg-lime-ink relative inline-flex size-2 rounded-full"></span>
        </span>
        <span class="text-ink font-medium">{site.availability}</span>
        <span class="hidden lg:inline" aria-hidden="true">·</span>
        <span class="hidden tabular-nums lg:inline"><span data-time>--:--</span> GER</span>
      </div>

      {/* smooth ⇄ instant scroll toggle */}
      <div class="scroll-ctl">
        <div class="scroll-toggle" data-active="smooth" role="group" aria-label="Scroll mode">
          <button
            type="button"
            data-scroll-mode="smooth"
            aria-pressed="true"
            aria-label="Smooth scrolling"
            title="Smooth scrolling"
          >
            <svg class="size-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path
                d="M3 12c2-4 4-4 6 0s4 4 6 0 4-4 6 0"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </button>
          <button
            type="button"
            data-scroll-mode="instant"
            aria-pressed="false"
            aria-label="Instant scrolling"
            title="Instant scrolling"
          >
            <svg class="size-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M13 2 L3 14 h9 l-1 8 l10 -12 h-9 l1 -8 Z"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</header>
